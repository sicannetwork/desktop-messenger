{
  "compilerOptions": {
    "target":           "ES2020",
    "module":           "CommonJS",
    "lib":              ["ES2020"],
    "outDir":           "dist-electron",
    "rootDir":          ".",
    "strict":           true,
    "esModuleInterop":  true,
    "skipLibCheck":     true,
    "resolveJsonModule": true,
    "declaration":      false,
    "sourceMap":        true,
    "baseUrl":          ".",
    "paths": {
      "shared/*": ["./shared/*"]
    }
  },
  "include": ["electron", "shared"],
  "exclude": ["src", "dist", "node_modules"]
}
